# Supabase pooled connection URL for app runtime.
# Example only. Put the real value in Vercel env vars, never in Git.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase direct connection URL for Prisma migrations.
# Example only. Put the real value in Vercel env vars, never in Git.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Required by the custom cookie session auth.
AUTH_SECRET="replace-with-a-long-random-secret"

# Public URLs used by CTA links.
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"
NEXT_PUBLIC_LINE_URL="https://line.me/R/ti/p/@mimi"
NEXT_PUBLIC_INSTAGRAM_URL="https://instagram.com/"
